RESILIO_ACCEPT_TERMS=false
RESILIO_WEBUI_USER=artemis-relay
RESILIO_WEBUI_PASSWORD=
RESILIO_IDENTITY=Artemis Relay Docker
RESILIO_SHARE_LINK=
RESILIO_SYNC_PATH=/mnt/mounted_folders/Artemis Dialogue Server
RESILIO_MONITOR_INTERVAL_SECONDS=30

ARTEMIS_RELAY_ENABLED=true
ARTEMIS_RELAY_BIND_HOST=127.0.0.1
ARTEMIS_RELAY_AUDIO_PORT=5670
ARTEMIS_RELAY_SERVER_LIST_PORT=5677
ARTEMIS_RELAY_INFORMATION_PORT=5684
ARTEMIS_RELAY_SERVICES=audio,information,server-list

ARTEMIS_UPNP_ENABLED=false
ARTEMIS_UPNP_INTERNAL_IP=
ARTEMIS_UPNP_LEASE_SECONDS=3600
ARTEMIS_UPNP_REFRESH_INTERVAL_SECONDS=1800
ARTEMIS_UPNP_AUDIO_EXTERNAL_PORT=5670
ARTEMIS_UPNP_SERVER_LIST_EXTERNAL_PORT=5677
ARTEMIS_UPNP_INFORMATION_EXTERNAL_PORT=5684
